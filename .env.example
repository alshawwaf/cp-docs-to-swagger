# Check Point Management Server Configuration
# Copy this file to .env and update with your actual server details

# Check Point Management Server URL (Used for "Try it out" feature in Swagger UI)
# This is the address of the actual server you want to test commands against.
# Documentation is automatically fetched from Check Point's online documentation servers.
# Example: https://<your-mgmt-server-ip>/web_api
CHECKPOINT_SERVER_URL=https://<mgmt-server-ip>/web_api

# Check Point GAiA API Server URL (Used for "Try it out" feature in Swagger UI)
# Example: https://<your-gaia-server-ip>/gaia_api
GAIA_SERVER_URL=https://<gaia-server-ip>/gaia_api

# Check Point API Version (optional - auto-discovers latest if not set)
# Management API versions: v1, v1.1, v1.2, v1.3, v1.4, v1.5, v1.6, v1.6.1, v1.7, v1.7.1, v1.8, v1.8.1, v1.9, v1.9.1, v2.0, v2.0.1
# GAiA API versions: v1, v1.1, v1.2, v1.3, v1.4, v1.5, v1.6, v1.7, v1.8
# Leave empty for automatic version discovery
CHECKPOINT_API_VERSION=

# SSL Verification
# Set to 'true' to enable SSL certificate verification (recommended for production)
# Default: false (allows self-signed certificates)
VERIFY_SSL=false

# Show Undocumented API Calls
# Set to 'true' to include unpublished/undocumented API calls in the documentation
# These are commands marked with "documented": false in the source data
# Default: false (hides undocumented APIs)
SHOW_UNDOCUMENTED=false
